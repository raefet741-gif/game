# ── KYUUBI arcade — environment ───────────────────────────────────────────
# Google Gemini API key, used by the Puzzle game to turn a photo/selfie into an
# AI-generated puzzle image. OPTIONAL: without a key, the uploaded photo/selfie
# is used as the puzzle directly (the game still works fully).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini image model used for generation.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: the vision model DOODLE DUEL uses to score drawings against the
# target word (AI judging). If the key can't reach it, the game automatically
# falls back to a player vote, so this is never required.
GEMINI_TEXT_MODEL=gemini-2.0-flash

# ── Persistent accounts database (IMPORTANT for production) ────────────────
# WITHOUT this, accounts (XP / coins / logins) are stored in a local JSON file
# under server/data/ — which is WIPED on every deploy/restart on ephemeral hosts
# like Render/Koyeb/Fly free tiers, so players lose their data each push.
# Set DATABASE_URL to a hosted Postgres (Neon, Supabase, Render Postgres…) and
# the whole accounts DB persists across deploys. Leave blank for local dev.
# DATABASE_URL=postgres://user:password@host/dbname
# DATABASE_SSL=off   # only for a plain local Postgres without SSL

# Optional: server port (defaults to 3000)
# PORT=3000
