# ── KYUUBI arcade — environment ───────────────────────────────────────────
# Google Gemini API key, used by the Puzzle game to turn a photo/selfie into an
# AI-generated puzzle image. OPTIONAL: without a key, the uploaded photo/selfie
# is used as the puzzle directly (the game still works fully).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini image model used for generation.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: server port (defaults to 3000)
# PORT=3000
